# Copy file này thành ".env" rồi điền giá trị thật vào

# ID của Google Sheet (lấy từ URL, đoạn giữa /d/ và /edit)
# VD: https://docs.google.com/spreadsheets/d/1POJ45a6sEcsE_hWn0mR6kr6IDZKrQAjpASiHo4DT_O0/edit
# -> GOOGLE_SHEET_ID=1POJ45a6sEcsE_hWn0mR6kr6IDZKrQAjpASiHo4DT_O0
GOOGLE_SHEET_ID=

# Đường dẫn tới file JSON key của Service Account (xem hướng dẫn trong README.md)
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./credentials/service-account.json

# Cổng chạy server (mặc định 3000)
PORT=3000
